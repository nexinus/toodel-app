<div class="container mx-auto p-6">
  <h1 class="text-3xl font-bold text-gray-800 mb-8">My Matches</h1>

  <!-- Logged-in user info -->
  <% if current_user %>
    <div class="mb-6 p-4 bg-blue-100 rounded-lg">
      <h2 class="text-lg font-semibold text-blue-800">Logged in as:</h2>
      <p class="text-gray-800">
        <strong><%= current_user.name %></strong> (<%= current_user.email %>)
      </p>
    </div>
  <% end %>

  <!-- Navigation -->
  <div class="mb-6 flex space-x-4">
    <%= link_to 'Discover People', discover_path, 
        class: 'px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600' %>
    <%= link_to 'Dashboard', dashboard_path, 
        class: 'px-4 py-2 bg-purple-500 text-white rounded-lg hover:bg-purple-600' %>
  </div>

  <!-- Matches section -->
  <div class="mb-8">
    <h2 class="text-2xl font-semibold mb-4 text-gray-700">Your Matches</h2>
    
    <% if @matches.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @matches.each do |match| %>
          <div class="p-6 border rounded-lg shadow-md bg-white hover:shadow-lg transition-shadow">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-800"><%= match.target.name %></h3>
              <% if mutual_match?(match) %>
                <span class="px-2 py-1 bg-green-100 text-green-800 text-xs rounded-full font-medium">
                  Mutual Match
                </span>
              <% else %>
                <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs rounded-full font-medium">
                  Waiting for Response
                </span>
              <% end %>
            </div>
            
            <div class="space-y-2 mb-4">
              <p class="text-gray-600"><strong>Role:</strong> <%= match.target.role %></p>
              <% if match.target.skills.present? %>
                <p class="text-gray-600"><strong>Skills:</strong> <%= match.target.skills %></p>
              <% end %>
              <% if match.target.bio.present? %>
                <p class="text-gray-600 text-sm"><%= truncate(match.target.bio, length: 100) %></p>
              <% end %>
            </div>
            
            <div class="text-sm text-gray-500 mb-4">
              Matched on: <%= match.swiped_at.strftime("%B %d, %Y") %>
            </div>
            
            <div class="flex space-x-2">
              <% if mutual_match?(match) %>
                <%= link_to 'Chat Now', chat_match_path(match), 
                    class: 'px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 font-medium flex-1 text-center' %>
                <%= link_to 'View Profile', match_path(match), 
                    class: 'px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 font-medium flex-1 text-center' %>
              <% else %>
                <span class="px-4 py-2 bg-gray-300 text-gray-600 rounded-lg font-medium flex-1 text-center">
                  Waiting for match
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-gray-50 rounded-lg">
        <div class="text-6xl mb-4">💔</div>
        <h3 class="text-xl font-semibold text-gray-700 mb-2">No matches yet</h3>
        <p class="text-gray-500 mb-6">Start discovering people to make your first match!</p>
        <%= link_to 'Discover People', discover_path, 
            class: 'px-6 py-3 bg-blue-500 text-white rounded-lg hover:bg-blue-600 font-medium' %>
      </div>
    <% end %>
  </div>

  <!-- Quick stats -->
  <% if @matches.any? %>
    <div class="bg-gray-50 rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-4 text-gray-700">Quick Stats</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-blue-600"><%= @matches.count %></div>
          <div class="text-sm text-gray-600">Total Matches</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-green-600">
            <%= @matches.count { |m| mutual_match?(m) } %>
          </div>
          <div class="text-sm text-gray-600">Mutual Matches</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-yellow-600">
            <%= @matches.count { |m| !mutual_match?(m) } %>
          </div>
          <div class="text-sm text-gray-600">Pending</div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Helper method for mutual match check -->
<% def mutual_match?(match)
     Match.exists?(user: match.target, target: match.user, kind: "connect")
   end %>

